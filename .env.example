GPU_DEVICE=0
MANAGER_PORT=8010
CHEM_HOST_PORT=8011
GEMMA_HOST_PORT=8012
ACTIVE_MODEL_KEY=gemma
CONTROL_TIMEOUT_SECONDS=300
HF_CACHE_DIR=$HOME/models

# MinIO / S3 configuration
MINIO_URL=https://api.blackhole2.ai.innopolis.university/
MINIO_ACCESS_KEY=replace_me
MINIO_SECRET_KEY=replace_me
MINIO_BUCKET=mass-spectrum-platform
CHEM_S3_PREFIX=models/chemdfm
GEMMA_S3_PREFIX=models/gemma
CHEM_LOCAL_DIR=$HOME/models/chemdfm
GEMMA_LOCAL_DIR=$HOME/models/gemma
CHEM_MODEL_LOCAL_PATH=/root/.cache/huggingface/chemdfm
GEMMA_MODEL_LOCAL_PATH=/root/.cache/huggingface/gemma
# Optional MinIO client override (auto-install used when unset)
# MC_BIN=/absolute/path/to/minio-mc

# Optional manager metadata overrides (labels shown by manager API)
# GEMMA_MODEL_ID=RedHatAI/gemma-3-27b-it-quantized.w8a8
# CHEM_MODEL_ID=OpenDFM/ChemDFM-R-14B
# CHEM_MAX_MODEL_LEN=4096
# GEMMA_MAX_MODEL_LEN=4096
# MAX_COMPLETION_TOKENS=1600
# CHEM_GPU_MEMORY_UTILIZATION=0.50
# GEMMA_GPU_MEMORY_UTILIZATION=0.90
